#!/bin/sh

# This is a simple script that requires an external text file filled with emojis.
# See ~/.local/share/00-emojis for the complete list.

emojidesc="$(cat ${XDG_DATA_HOME:-$HOME/.local/share}/00-emojis | dmenu -i -l 25 -p "Copy an emoji (ESC to cancel):")"
emojiicon="$(echo $emojidesc | cut -d' ' -f1)"
[ -z "$emojidesc" ] && exit 1

echo -n $emojiicon | xclip -i -selection clipboard >/dev/null 2>&1 && notify-send "Selected emoji copied to clipboard!" "$emojidesc"
