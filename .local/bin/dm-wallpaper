#!/bin/sh

# The main file for rendering wallpapers
bgmain="$HOME/.local/share/bg"
# Backgrounds folder
bgdir="$HOME/.local/share/backgrounds"

# Select wallpaper from backgrounds folder
selection() {
	chosen="$(ls "$bgdir" | dmenu -i -l 10 -p "Choose a wallpaper:")"
	[ -z "$chosen" ] && exit 1
	cp "$bgdir/$chosen" $bgmain && \
	notify-send "🌅 Wallpaper selected." "$bgdir/$chosen" -i "$bgdir/$chosen"
}

remove() {
	xwallpaper --clear && \
	notify-send "🛑 Wallpaper cleared." "Select a new wallpaper [or] execute xsetroot -solid [color]." && exit
}

while getopts "sr" z; do
	case ${z} in
		s) selection ;;
		r) remove ;;
	esac
done

# If given a file, then use that as wallpaper.
[ -f "$1" ] && cp "$1" "$bgmain" && \
	notify-send "🌅 Wallpaper selected." "$(readlink -f "$1")" -i "$(readlink -f "$1")"

# If given a directory, shuffle it then randomly pick one.
[ -d "$1" ] && cp "$(find "$1" -name "*.jpg" -o -name ".jpeg" -o -name "*.png" -type f | shuf -n 1)" "$bgmain" && \
	notify-send "🎱 Random wallpaper chosen."

# If no arguments, then just set the previous wallpaper.
xwallpaper --zoom $bgmain
