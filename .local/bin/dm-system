#!/bin/sh

act="$(printf "%s\n" "🖥 Shutdown - Turn the computer off" "🔃 Reboot - Restart the system" "📺 Display off - A simple black screen" | dmenu -i -fn Monospace-12 -l 6 -p "System action:")"
if ls -l /sbin/init | grep -q runit; then
	sys=loginctl
else
	sys=systemctl
fi

case "$act" in
	🖥*) $sys poweroff ;;
	🔃*) $sys reboot ;;
	📺*) xset dpms force off ;;
esac
