#!/bin/sh

case "$BUTTON" in
	1) $TERMINAL -e pulsemixer ;;
	3) notify-send "📢 Volume / Speakers" "Left-click to access audio mixer.
Shift+Left-click to mute/unmute." ;;
	4) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
	6) $TERMINAL -e $EDITOR "$0" ;;
esac

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print 🔇 and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && printf "🔇\\n" && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon="🔊" ;;
	$((vol >= 30)) ) icon="🔉" ;;
	$((vol >= 1)) ) icon="🔈" ;;
	* ) echo 🔇 && exit ;;
esac

printf "%s%s%%\\n" "$icon" "$vol"
