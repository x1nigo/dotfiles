#!/bin/sh

case "$BUTTON" in
	3) notify-send "📅 Date and Time" "Notice how the clock emoji reflects the actual hour of the day/night." ;;
	6) $TERMINAL -e $EDITOR "$0" ;;
esac

clock=$(date '+%I')

case "$clock" in
	"00") icon="🕛" ;;
	"01") icon="🕐" ;;
	"02") icon="🕑" ;;
	"03") icon="🕒" ;;
	"04") icon="🕓" ;;
	"05") icon="🕔" ;;
	"06") icon="🕕" ;;
	"07") icon="🕖" ;;
	"08") icon="🕗" ;;
	"09") icon="🕘" ;;
	"10") icon="🕙" ;;
	"11") icon="🕚" ;;
	"12") icon="🕛" ;;
esac

date "+%Y %b %d (%a) $icon%I:%M%p"
