#!/bin/sh

case "$BUTTON" in
	1) $TERMINAL -e pulsemixer ;;
	3) notify-send "🗣 Microphone" "Left-click to access audio mixer.
Shift+Left-click to mute/unmute." ;;
	4) wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle ;;
	6) $TERMINAL -e $EDITOR "$0" ;;
esac

mic="$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@)"

[ "$mic" != "${mic%\[MUTED\]}" ] && printf "⏹\\n"  && exit

mic="${mic#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

mic="$(printf "%.0f" "$(split "$mic" ".")")"

printf "🗣%s%%\\n" "$mic"
