#!/bin/sh

case "$BUTTON" in
	3) notify-send "🏠 Disk Space" "Shows the root directory's used space. Updates once in a while." ;;
	6) $TERMINAL -e $EDITOR "$0" ;;
esac

# Checks the current storage of the root ("/") directory.
if [ "$(df -h | awk '/\/$/ {print $5}' | sed 's/\%//')" -ge 50 ]; then
	df -h | awk '/\/$/ {print "🚩" $4, "(" $5, "used" ")"}'
else
	df -h | awk '/\/$/ {print "🏠" $4, "(" $5, "used" ")"}'
fi
