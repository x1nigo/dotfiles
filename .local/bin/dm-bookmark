#!/bin/sh

# To be used alongside the `dm-insert` script.
# `xclip` needs to be installed.

file="${XDG_DATA_HOME:-$HOME/.local/share}/01-bookmarks"
bookmark="$(xclip -o)"
[ -z $bookmark ] && notify-send "🛑 Unable to create a bookmark." "Please try again." && exit 1

if grep -q "^$bookmark" "$file"; then
	notify-send "🤡 Already bookmarked!" "Try again or look for a different one."
else
	printf "%s\\n" "$bookmark" >> "$file" && notify-send "🔖 Bookmark added!" "$bookmark"
fi
