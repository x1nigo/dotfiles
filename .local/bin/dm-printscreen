#!/bin/sh

selected() {
	maim --quality=10 -u -s $HOME/selected-$(date +%y-%m-%d-%s).png \
		&& notify-send "👉 Selected screenshot." "$HOME/selected-$(date +%y-%m-%d-%s).png"
}

activewin() {
	maim --quality=10 -u -i $(xdotool getactivewindow) $HOME/active-$(date +%y-%m-%d-%s).png \
		&& notify-send "🎯 Active window screenshot." "$HOME/active-$(date +%y-%m-%d-%s).png"
}

chosen=$(printf "%s\n" "🌅 Desktop - The entire screen" "👉 Selected area - Click and drag" "🎯 Active window - The focused window" | dmenu -i -l 6 -p "Take a picture of (ESC to cancel):")

case "$chosen" in
	🌅*) maim --quality=10 -u $HOME/desktop-$(date +'%y-%m-%d-%s').png \
		&& notify-send "🌅 Desktop screenshot." "$HOME/desktop-$(date +'%y-%m-%d-%s').png" ; exit ;;
	👉*) selected ;;
	🎯*) activewin ;;
esac
