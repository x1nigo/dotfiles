#!/bin/sh

audio() { ffmpeg \
	-f alsa \
	-i default \
	"$HOME/audio-$(date '+%y%b%d-%I%M').wav" & \
	echo $! > /tmp/recordingpid
	echo "⏺" > /tmp/recordingicon && pkill -RTMIN+4 dwmblocks
}

video() { ffmpeg \
	-framerate 30 \
	-f x11grab \
	-i "$DISPLAY" \
	"$HOME/video-$(date '+%y%b%d-%I%M').mkv" & \
	echo $! > /tmp/recordingpid
	echo "🎥" > /tmp/recordingicon && pkill -RTMIN+4 dwmblocks
}

screenaudio() { ffmpeg \
	-framerate 30 \
	-f x11grab \
	-i "$DISPLAY" \
	-f alsa \
	-i default \
	"$HOME/screen-$(date '+%y%b%d-%I%M').mp4" & \
	echo $! > /tmp/recordingpid
	echo "🎥⏺" > /tmp/recordingicon && pkill -RTMIN+4 dwmblocks
}

killrecordings() {
	recordpid="$(cat /tmp/recordingpid)"
	[ -z "$recordpid" ] && notify-send "❓ No recording found." "Double-check system processes." && exit
	kill -15 "$recordpid" && \
	rm -f /tmp/recordingpid /tmp/recordingicon && \
	notify-send "⏹ Stopped recording." "See home directory for the file."
	pkill -RTMIN+4 dwmblocks
}

# If no argument given, use `dmenu`.
if [ -z "$1" ]; then
	recording="$(printf "audio - record audio only without video\\nvideo - video recording without audio\\nscreenaudio - record both audio and video\\nstop - kill any current recording processes" | dmenu -i -l 6 -p "Select type of recording:")"

	case "$recording" in
		audio*) audio ;;
		video*) video ;;
		screenaudio*) screenaudio ;;
		stop*) killrecordings ;;
		*) exit ;;
	esac
fi

# In case an argument is given:
case "$1" in
	audio) audio ;;
	video) video ;;
	screenaudio) screenaudio ;;
	stop) killrecordings ;;
	*) exit ;;
esac
